PORT=5000

# ==================== DATABASE ====================
# PostgreSQL connection string (Supabase or any PG)
DATABASE_URL=postgresql://user:password@host:5432/database

# ==================== SUPABASE AUTH (OTP) ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==================== JWT ====================
# Generate a strong random key: require('crypto').randomBytes(32).toString('hex')
JWT_SECRET=your-strong-jwt-secret-at-least-32-chars

# ==================== APP CONFIG ====================
NODE_ENV=development
APP_NAME=MyMart
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ==================== SENDGRID EMAIL ====================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_SENDER_EMAIL=your-email@example.com
SENDGRID_SENDER_NAME=MyMart

# ==================== STRIPE PAYMENT ====================
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# ==================== DELIVERY CONFIG ====================
DELIVERY_BASE_FEE=3.00
FREE_DELIVERY_THRESHOLD=35.00
